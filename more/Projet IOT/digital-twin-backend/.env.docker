# Configuration Backend pour Docker
PORT=3000
NODE_ENV=production

# MQTT Broker (localhost car dans le même réseau Docker)
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_CLIENT_ID=DigitalTwin_Backend
MQTT_TOPICS=esp8266/#,raspberry/#

# InfluxDB (optionnel - peut être désactivé)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=my-super-secret-auth-token
INFLUXDB_ORG=iot-flacons
INFLUXDB_BUCKET=iot_flacons

# WebSocket CORS (permettre toutes les origines)
WS_CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
